# MongoDB Configuration
MONGODB_URL=
DATABASE_NAME=icann_tlds_db

# ICANN CZDS Credentials
ICANN_USERNAME=
ICANN_PASSWORD=
ICANN_AUTH_URL=https://account-api.icann.org
ICANN_CZDS_URL=https://czds-api.icann.org

# Scheduler Configuration (comma-separated hours, 24h format)
SCHEDULE_HOURS=6,12,18

# Zone Files Directory
ZONE_FILES_DIR=./zonefiles

# WHOIS Configuration (optional)
WHOIS_ENABLED=false
WHOIS_RATE_LIMIT=5

# Logging
LOG_LEVEL=INFO
